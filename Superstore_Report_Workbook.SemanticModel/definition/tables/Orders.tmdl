table Orders
	lineageTag: a676c6e2-3573-4bad-b7fa-ba5965830323

	measure 'Total Sales' = SUM(Orders[Sales])
		displayFolder: Measure
		lineageTag: 4ebcc601-36be-406b-88b2-210cae4ceb26

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Profit' = SUM(Orders[Profit])
		displayFolder: Measure
		lineageTag: 0cd2a0c3-6e3b-4635-9f53-03ae11420632

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Quantity' = SUM(Orders[Quantity])
		formatString: 0
		displayFolder: Measure
		lineageTag: f7b114ed-1c9d-4c23-b339-468678eb0783

	measure 'Profit Margin %' = [Total Profit]/[Total Sales]
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Measure
		lineageTag: a630c0f6-f262-4f9c-b909-12bd98f0d9de

	measure 'Sales IND' =
			IF(
			    [Total Sales] > 50000,
			    "High Sales",
			    "Low Sales")
		displayFolder: Measure
		lineageTag: 5005d500-e7e9-40be-a858-ccd16048c1a4

	measure Target = 100000
		formatString: 0
		displayFolder: Measure
		lineageTag: 59d707b5-e1dc-4395-831e-1b56141d415c

	measure 'Total Orders' = DISTINCTCOUNT(Orders[Order ID])
		displayFolder: Measure
		lineageTag: 8e17a99a-4b89-432e-9177-0b298c3315ea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PY SALES' = CALCULATE(SUM(Orders[Sales]),SAMEPERIODLASTYEAR('DATE TBL'[Date]))
		formatString: 0.00
		displayFolder: Measure
		lineageTag: 49d32e12-17ab-44f0-a786-4c7cf2a23729

	measure 'PROFIT STATUS' = IF([Total Profit]>0,"PROFIT","LOSS")
		displayFolder: Measure
		lineageTag: 48ad3403-b58b-4d23-bf73-2ec6e426e73d

	measure 'PP SALES' = CALCULATE(SUM(Orders[Sales]),PARALLELPERIOD('DATE TBL'[Date],-1,YEAR))
		formatString: 0.00
		displayFolder: Measure
		lineageTag: 31b267ae-a53a-48d2-993f-3033a15efde7

	measure 'Sales for Corp' = CALCULATE(SUM(Orders[Sales]),FILTER(Orders,Orders[Segment] = "Corporate"))
		displayFolder: Measure
		lineageTag: 89bbe322-2cf8-41a5-a845-aaae8c594fb6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AVG Sales per Sub Category Code' =
			
			AVERAGEX(
				KEEPFILTERS(VALUES('Orders'[Sub Category Code])),
				CALCULATE(SUM('Orders'[Sales]))
			)
		lineageTag: da55928e-2941-4350-b61c-0cbe4b67496a

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "AveragePerCategory"
				}

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure MAX_VAL = MAX([Total Sales],[Total Profit])
		lineageTag: 91274625-b08f-4b35-b328-c9f0a4dabcb0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure SUMEXP = SUMX(Orders,Orders[Sales]*Orders[Quantity])
		displayFolder: Measure
		lineageTag: 50344e67-d435-471d-8221-7f0e80a80e7a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

