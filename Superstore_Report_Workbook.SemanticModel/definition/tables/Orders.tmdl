	column 'Discount (bins)' =
			IF(
				ISBLANK('Orders'[Discount]),
				BLANK(),
				IF(
					'Orders'[Discount] >= 0,
					ROUNDDOWN('Orders'[Discount] / 0.1, 0) * 0.1,
					ROUNDUP('Orders'[Discount] / 0.1, 0) * 0.1
				)
			)
