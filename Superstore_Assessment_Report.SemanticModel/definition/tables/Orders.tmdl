table Orders
	lineageTag: 45e1d129-c321-4874-b74a-39e953b0307d

	measure 'TOTAL SALES' = SUM(Orders[Sales])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Measures
		lineageTag: 1d1360c4-fa6d-4af1-9993-b47a2ac04904

	measure 'TOTAL PROFIT' = SUM(Orders[Profit])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Measures
		lineageTag: 70d87819-e72d-49fa-adf6-93d1a1b7967d

	measure 'TOTAL ORDERS' = DISTINCTCOUNT(Orders[Order ID])
		formatString: 0
		displayFolder: Measures
		lineageTag: b69f979f-af37-402d-8777-a811658fbd10

	measure 'AVERAGE DISCOUNT' = AVERAGE(Orders[Discount])
		displayFolder: Measures
		lineageTag: 9b956f11-8bdb-44f1-ab62-4d587edc7792

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'SALES YTD' = TOTALYTD([TOTAL SALES],DATE_TBL[Date])
		displayFolder: Measures
		lineageTag: f850dc95-7beb-4cd3-bdbe-a28f2fdd81c8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PY SALES' = CALCULATE([TOTAL SALES],SAMEPERIODLASTYEAR(DATE_TBL[Date]))
		displayFolder: Measures
		lineageTag: 9a8ecb03-378b-4d7d-ac07-6396677d724b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YOY SALES' = DIVIDE(([TOTAL SALES]-[PY SALES]),[PY SALES],0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Measures
		lineageTag: 63859823-23c3-4b53-ac82-d7f14a5103df

	measure 'Page Title' = ```
			" Sales Analysis - " & SELECTEDVALUE(Orders[Segment]," All Segment") 
			```
		lineageTag: 199ff66a-64ee-4672-a0b6-9600fdca89b0

	measure 'Year Selection' = "YEAR: " & SELECTEDVALUE(DATE_TBL[Date].[Year],"All")
		displayFolder: Measures
		lineageTag: 0cb1c45f-468d-45b9-bd20-1831d214f86e

	measure 'SALES RANK' = RANKX(ALL(Orders[Product Name]),[TOTAL SALES],,DESC)
		formatString: 0
		displayFolder: Measures
		lineageTag: ffefafca-0dfe-428f-b242-6393ce233bb7

	measure TOPN = IF('TOPN'[TOPN Value]>=[SALES RANK],1,0)
		formatString: 0
		displayFolder: Measures
		lineageTag: a53b09f8-63e0-4903-ad90-42be6f4d30bc

	measure Rank = RANKX(Orders,[TOTAL SALES],,DESC)
		formatString: 0
		displayFolder: Measures
		lineageTag: de366521-8f8b-4da7-b0b6-7ba70625800b

	measure '3-Month Moving AVG Sales' = AVERAGEX(DATESINPERIOD(DATE_TBL[Date],LASTDATE(DATE_TBL[Date]),-3,MONTH),[TOTAL SALES])
		displayFolder: Measures
		lineageTag: dd7b4d8f-611e-41e1-a5db-c251339d8708

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AVG_SALES = AVERAGE(Orders[Sales])
		displayFolder: Measures
		lineageTag: 3f92aca8-48ca-4103-ad65-c554e9a3cbba

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure OCCURRENCE_SALES = COUNTROWS(Orders)
		formatString: 0
		displayFolder: Measures
		lineageTag: df9bef19-7ee1-41d0-a42a-c86b820c2856

	measure LSTDT = DISTINCTCOUNT(Orders[Order Date])
		formatString: 0
		displayFolder: Measures
		lineageTag: d829dd34-d03f-4f14-9c77-64f1a71ab97a

	measure '3 Month Moving Avg' =
			
			CALCULATE(
			    AVERAGEX(
			        VALUES(DATE_TBL[YearMonth]),
			        [TOTAL SALES]
			    ),
			    DATESINPERIOD(
			        DATE_TBL[Date],
			        MAX(DATE_TBL[Date]),
			        -3,
			        MONTH
			    )
			)
		displayFolder: Measures
		lineageTag: 422b52e5-7788-4943-bcaf-fdc3037bf350

	measure '6 Month Moving Avg' =
			
			CALCULATE(
			    AVERAGEX(
			        VALUES(DATE_TBL[YearMonth]),
			        [TOTAL SALES]
			    ),
			    DATESINPERIOD(
			        DATE_TBL[Date],
			        MAX(DATE_TBL[Date]),
			        -6,
			        MONTH
			    )
			)
		displayFolder: Measures
		lineageTag: d8bac787-62b6-4851-8e19-23edc37f9a20

		annotation PBI_FormatHint = {"isGeneralNumber":true}

