	column 'PROFIT MARGIN %' = ```
			DIVIDE(Orders[Profit],Orders[Sales],0) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 07ca66af-6494-4bb5-a8c5-2de079380491
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation __PBI_SemanticLinks = [{"LinkTarget":{"TableName":"Orders","TableItemName":"PROFIT MARGIN % (bins)","ObjectType":4},"LinkType":"UsedInGroup"}]

	column 'PROFIT MARGIN % (bins)' =
			IF(
				ISBLANK('Orders'[PROFIT MARGIN %]),
				BLANK(),
				IF(
					'Orders'[PROFIT MARGIN %] >= 0,
					ROUNDDOWN('Orders'[PROFIT MARGIN %] / 0.2, 0) * 0.2,
					ROUNDUP('Orders'[PROFIT MARGIN %] / 0.2, 0) * 0.2
				)
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 65f7f4ca-42a2-4305-8489-7cc01e11ae95
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
				  "version": 0,
				  "groupedColumns": [
				    {
				      "Column": {
				        "Expression": {
				          "SourceRef": {
				            "Entity": "Orders"
				          }
				        },
				        "Property": "PROFIT MARGIN %"
				      }
				    }
				  ],
				  "binningMetadata": {
				    "binSize": {
				      "value": 0.2,
				      "unit": 0
				    }
				  }
				}

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"o","Entity":"Orders"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"o"}},"Property":"PROFIT MARGIN %"}}],"BinItem":{"Expression":{"Floor":{"Expression":{"Column":{"Expression":{"SourceRef":{"Source":"o"}},"Property":"PROFIT MARGIN %"}},"Size":0.2}}}}

		annotation SummarizationSetBy = Automatic

